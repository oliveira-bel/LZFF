library(testthat)
load_all()
#helper-formatPed
check_ped_ascii <- function(pedObj) {
dadosPedTemp <- sapply(pedObj$ped, paste0, collapse = " ")
stopifnot(all(grepl("^[ -~]+$", dadosPedTemp)))
invisible(TRUE)
}
test()
